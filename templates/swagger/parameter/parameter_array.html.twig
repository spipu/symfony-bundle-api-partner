<span class="badge text-bg-secondary">{{ parameter.name }}</span>

{% if parameter.isRequired %}
    <span class="badge text-bg-warning">required</span>
{% endif %}

{% if parameter.minItems is not null %}
    <span class="badge text-bg-light">
        &gt;{% if not parameter.exclusiveMin %}={% endif %} {{ parameter.minItems }} item{% if parameter.minItems>1 %}s{% endif %}
    </span>
{% endif %}

{% if parameter.maxItems is not null %}
    <span class="badge text-bg-light">
        &lt;{% if not parameter.exclusiveMax %}={% endif %} {{ parameter.maxItems }} item{% if parameter.maxItems>1 %}s{% endif %}
    </span>
{% endif %}
<br />

{% if parameter.defaultValue is not null %}
    <small>Default value:</small><span class="badge text-bg-light">Yes</span>
    <br />
{% endif %}

{% if parameter.description %}
    <span class="small font-italic ms-4">{{ parameter.description|raw }}</span>
    <br />
{% endif %}

<div class="ms-4">
    <small>Array of</small>
    {% include '@SpipuApiPartner/swagger/parameter.html.twig' with {'parameter': parameter.itemParameter} %}
</div>
